#! /usr/bin/env bash
# If a process is running, send SIGUSR1 to it.
# Otherwise, start the provided command through uwsm.
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: $(basename "$0") PROCESS [ARGS...]" >&2
  exit 1
fi

process="$1"
shift

pid="$(pgrep "$process" | head -n1 || true)"

if [[ -n "$pid" ]]; then
  kill -SIGUSR1 "$pid"
else
  exec uwsm app -- "$@"
fi
